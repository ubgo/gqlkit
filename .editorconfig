# https://editorconfig.org — consistent whitespace across editors.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{yml,yaml,json,jsonc,toml}]
indent_style = space
indent_size = 2

[*.{js,ts,jsx,tsx,css,html}]
indent_style = space
indent_size = 2

[*.graphql]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
